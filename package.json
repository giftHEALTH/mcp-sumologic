{
  "name": "mcp-sumologic",
  "version": "1.0.0",
  "description": "Read-only MCP server for Sumo Logic: log search, aggregation, metadata, metrics, monitors, and content",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "NODE_PATH=./dist node -r tsconfig-paths/register dist/index.js",
    "start:http": "NODE_PATH=./dist node -r tsconfig-paths/register dist/index.js http",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'tsx' src/index.ts",
    "dev:http": "nodemon --watch 'src/**/*.ts' --exec 'tsx' src/index.ts http",
    "build": "tsc && tsc-alias",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "prepare": "husky install"
  },
  "author": "justinko",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giftHEALTH/mcp-sumologic.git"
  },
  "homepage": "https://github.com/giftHEALTH/mcp-sumologic#readme",
  "bugs": {
    "url": "https://github.com/giftHEALTH/mcp-sumologic/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@types/express": "^5.0.3",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "moment": "^2.30.1",
    "query-string": "^8.1.0",
    "ramda": "^0.29.1",
    "request": "^2.88.2",
    "request-promise-native": "^1.0.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@types/ramda": "^0.29.11",
    "@types/request": "^2.48.12",
    "@types/request-promise-native": "^1.0.21",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.6",
    "tsx": "^4.7.1",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
