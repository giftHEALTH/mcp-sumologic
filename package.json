{
  "name": "mcp-sumologic",
  "version": "1.0.0",
  "description": "Read-only MCP server for Sumo Logic: log search, aggregation, metadata, metrics, monitors, and content",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "NODE_PATH=./dist node -r tsconfig-paths/register dist/index.js",
    "start:http": "NODE_PATH=./dist node -r tsconfig-paths/register dist/index.js http",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'tsx' src/index.ts",
    "dev:http": "nodemon --watch 'src/**/*.ts' --exec 'tsx' src/index.ts http",
    "build": "tsc && tsc-alias",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "test": "jest --passWithNoTests",
    "prepare": "husky"
  },
  "author": "justinko",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giftHEALTH/mcp-sumologic.git"
  },
  "homepage": "https://github.com/giftHEALTH/mcp-sumologic#readme",
  "bugs": {
    "url": "https://github.com/giftHEALTH/mcp-sumologic/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "moment": "^2.30.1",
    "query-string": "^9.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": ">=24.16.0"
  }
}
